# Режим работы:
#   MOCK — без вызовов API, заглушки. Бесплатно. Дефолт для разработки.
#   REAL — реальная генерация. Включать перед живым прогоном.
HF_MODE=MOCK

# Провайдер генерации: gemini (Nano Banana) | openai (GPT Image 2) | higgsfield
HF_PROVIDER=gemini

# --- Gemini / Nano Banana ---
# Бесплатный ключ: https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-image-preview

# --- OpenAI / GPT Image 2 (силён в тексте) ---
# Ключ: https://platform.openai.com  (отдельный pay-as-you-go биллинг)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-image-2
OPENAI_QUALITY=medium   # low|medium|high — баланс цена/качество

# Гибрид 10.A: правильный текст ТЗ поверх инфографики (1=вкл, 0=чистый визуал)
HF_TEXT_OVERLAY=1
# Шрифт с кириллицей для текст-слоя. Пусто = автопоиск (macOS Arial /
# Linux DejaVu). Задать путь, если шрифт в нестандартном месте.
FONT_PATH=

# --- Higgsfield (запасной провайдер) ---
# Формат: KEY_ID:KEY_SECRET (платный тариф Creator)
HF_CREDENTIALS=

# Модель и профиль качества. economy — дешёвый по умолчанию (TZ 7.7д).
HF_MODEL=flux-pro/kontext/max/text-to-image
HF_QUALITY=economy

# Лимит одновременных задач к Higgsfield (TZ: лимит конкурентности)
HF_CONCURRENCY=3

# Повторов на упавшую генерацию (обработка брака, TZ 7.6)
HF_MAX_RETRIES=2

# Грубая цена за 1 генерацию в USD — для сметы перед прогоном (TZ 7.7в).
# Уточнить по факту тарифа Higgsfield Creator.
HF_PRICE_PER_IMAGE=0.05

# --- Telegram ---
# Токен бота от @BotFather
TELEGRAM_TOKEN=
# Кто может пользоваться (TZ 7.2). Список Telegram user_id через запятую.
# ПУСТО = бот не пустит НИКОГО (защита платного API-бюджета).
HF_ALLOWED_USER_IDS=
